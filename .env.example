# ============================================
# AI VIDEO AUTOMATION - OVER POWER EDITION
# ============================================

# OpenAI API Key (untuk generate script & ide video)
OPENAI_API_KEY=your_openai_api_key_here

# Google API (YouTube Data API v3)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token

# TikTok API
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ElevenLabs API (untuk text-to-speech/narration)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# Pexels API (untuk stock footage)
PEXELS_API_KEY=your_pexels_api_key

# Unsplash API (untuk stock images)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Video Settings
DEFAULT_VIDEO_WIDTH=1920
DEFAULT_VIDEO_HEIGHT=1080
DEFAULT_FPS=30
DEFAULT_VIDEO_FORMAT=mp4

# Upload Schedule (cron format)
YOUTUBE_CRON=0 9,14,19 * * *
TIKTOK_CRON=0 10,15,20 * * *
MAX_VIDEOS_PER_DAY=5

# Smart Scheduler Settings
MIN_GAP_BETWEEN_UPLOADS=120
RETRY_FAILED_UPLOADS=true
RETRY_DELAY_MINUTES=60

# Dashboard Settings
DASHBOARD_PORT=3001
ENABLE_DASHBOARD=true

# Analytics Settings
ANALYTICS_COLLECT_INTERVAL=60

# Database
DATABASE_PATH=./data/automation.db

# Output Directory
OUTPUT_DIR=./output
TEMP_DIR=./output/temp

# Watermark Settings
ENABLE_WATERMARK=false
WATERMARK_PATH=./assets/watermark.png

# Caption Settings
ENABLE_AUTO_CAPTION=true
CAPTION_FONT_SIZE=48
CAPTION_POSITION=bottom

# Intro/Outro
ENABLE_INTRO=false
INTRO_PATH=./assets/intro.mp4
ENABLE_OUTRO=false
OUTRO_PATH=./assets/outro.mp4

# Background Music
ENABLE_BACKGROUND_MUSIC=true
MUSIC_VOLUME=0.3
MUSIC_PATH=./assets/music

# Content Calendar
CALENDAR_WEEKS_AHEAD=2
VIDEOS_PER_WEEK=14

# Multi-Account Settings
MAX_ACCOUNTS_PER_PLATFORM=5
ENABLE_CROSS_POSTING=false

# Niche Settings (comma-separated)
ENABLED_NICHES=technology,science,history,mystery,finance,health,psychology,philosophy,space,nature
